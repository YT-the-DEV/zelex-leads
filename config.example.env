# Zelex Leads Configuration
# Copy this to config.env and fill in your values

# Target niches (comma-separated)
NICHE=restaurants,cafes,salons,dentists,gyms,plumbers,electricians

# Target cities (comma-separated, focus on US/UK)
TARGET_CITIES=New York,London,Los Angeles,Chicago,Miami,Houston,Manchester,Birmingham

# SendGrid (get free API key from sendgrid.com)
SENDGRID_API_KEY=

# Email settings
FROM_EMAIL=hello@zelexstudio.in
FROM_NAME=Zelex Studio

# Daily email limit (SendGrid free = 100/day)
DAILY_EMAIL_LIMIT=50

# Scrape settings
MAX_RESULTS_PER_NICHE=20
MIN_WEBSITE_SCORE=50
